# ─── Kushki MCP Server ─────────────────────────────────────────────────────────
# Copia este archivo como .env y completa los valores REALES antes de usar.
#   cp .env.example .env && chmod 600 .env
# ─────────────────────────────────────────────────────────────────────────────

# Merchant-Id PÚBLICO de Kushki (para tokenización de tarjetas).
KUSHKI_PUBLIC_KEY=

# Merchant-Id PRIVADO de Kushki (para cobros y mutaciones).
KUSHKI_PRIVATE_KEY=

# Ambiente: sandbox | production
KUSHKI_ENVIRONMENT=sandbox

# (Opcional) Timeout HTTP en segundos.
# KUSHKI_HTTP_TIMEOUT=30

# Opciones: sse | http_stream
MCP_TRANSPORT_MODE=sse
MCP_PORT=8000
